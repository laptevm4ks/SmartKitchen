<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход</title>
    <link rel="stylesheet" href="/style.css">
    <%- include('_pwa_head') %>
  </head>
  <body>
    <div class="app-container flex-center">
      <div class="glass-panel" style="max-width: 450px; width: 100%; text-align: center;">
        <h1>Вход</h1>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="status-msg error" style="display: block; margin-bottom: 20px;">
          <%= error %>
        </div>
        <% } %>

        <form action="/login" method="POST" style="display: flex; flex-direction: column; gap: 20px;">
          <input 
            type="email" 
            name="email" 
            class="form-control" 
            placeholder="Email" 
            required 
            value="<%= typeof email !== 'undefined' ? email : '' %>" 
          /> 
          
          <input 
            type="password" 
            name="password" 
            class="form-control" 
            placeholder="Пароль" 
            required 
          />

          <button type="submit" class="btn btn-primary" style="margin: 10px 0;">Войти</button>
        </form>

        <p style="margin-top: 25px;">Нет аккаунта? <a href="/register">Зарегистрироваться</a></p>
      </div>
    </div>
  </body>
</html>
