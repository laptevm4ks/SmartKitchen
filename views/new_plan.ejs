<!DOCTYPE html>
<html lang="ru">
  <head>
    <title><%= plan.plan_name %></title>
    <link rel="stylesheet" href="/style.css">
    <%- include('_pwa_head') %>
    <style>
      .plan-info { background: white; padding: 20px; border-radius: 15px; border: 2px solid var(--color-bg-accent); box-shadow: 3px 5px 15px rgba(93, 64, 55, 0.08); text-align: center; margin-bottom: 30px; }
      .plan-info p { font-size: 1.2rem; margin-bottom: 0; }

      .day-card { background: white; border: 2px solid var(--color-bg-accent); border-radius: 15px; margin-bottom: 20px; overflow: hidden; }
      .day-header { background-color: var(--color-highlight); padding: 15px 20px; font-size: 1.3rem; color: var(--color-text-main); border-bottom: 2px dashed var(--color-bg-accent); text-transform: capitalize; }
      .empty-day { padding: 20px; color: #a1887f; font-style: italic; }
      .meal-list { list-style: none; padding: 0; margin: 0; }
      .meal-item { display: flex; align-items: center; padding: 15px 20px; border-bottom: 1px solid var(--color-bg-accent); }
      .meal-item:last-child { border-bottom: none; }
      .meal-item.cooked { background-color: #f1f8e9; }
      .meal-type { font-weight: bold; color: var(--color-accent-primary); width: 100px; }
      .meal-title { flex: 1; color: var(--color-text-main); text-decoration: none; font-weight: 600; }
      .meal-item.cooked .meal-title { text-decoration: line-through; color: #8d6e63; }
      .meal-actions { display: flex; gap: 10px; align-items: center; }
      
      .btn-cook { background-color: #81c784; border-color: #388e3c; box-shadow: 2px 3px 0px #388e3c; color: white; padding: 5px 10px; font-size: 0.9rem; margin:0; }
      .btn-cook:hover { background-color: #66bb6a; color: white; }
      .status-cooked { color: var(--color-success); font-weight: bold; font-size: 0.9rem; }
      
      .btn-delete { background-color: var(--color-delete-btn, #ef5350); border-color: #c62828; box-shadow: 2px 3px 0px #c62828; color: white; padding: 5px 10px; font-size: 0.9rem; margin:0; }
      .btn-delete:hover { background-color: #e53935; color: white; }

      .tools-section { display: flex; justify-content: center; gap: 20px; margin: 40px 0; }
      .tools-section form { margin: 0; background: transparent; padding: 0; border: none; box-shadow: none; }
      .btn-shopping { background-color: #4caf50; border-color: #2e7d32; box-shadow: 4px 6px 0px #2e7d32; color: white; font-size: 1.1rem; padding: 15px 25px; margin: 0; width: 100%; }
      .btn-shopping:hover { background-color: #66bb6a; color: white; }
      .btn-print { background-color: #607d8b; border-color: #37474f; box-shadow: 4px 6px 0px #37474f; color: white; font-size: 1.1rem; padding: 15px 25px; margin: 0; }
      .btn-print:hover { background-color: #78909c; color: white; }

      @media print {
        body { background: white; padding: 0; }
        .main-header, .add-meal-section, .tools-section, .meal-actions, .btn { display: none !important; }
        .day-card { border: 1px solid #000; break-inside: avoid; margin-bottom: 10px; }
        .day-header { background-color: #f0f0f0; border-bottom: 1px solid #000; }
        .plan-info { border: none; box-shadow: none; padding: 0; margin-bottom: 20px; }
      }
    </style>
  </head>
  <body>
    <%- include('partials/header', { showBackButton: true, title: plan.plan_name }) %>
    <div class="app-container">
    <%
      // Вспомогательная функция для форматирования даты в YYYY-MM-DD с учетом локального времени
      const formatYMD = (date) => {
        const d = new Date(date);
        const offset = d.getTimezoneOffset() * 60000;
        return new Date(d.getTime() - offset).toISOString().split('T')[0];
      };

      const startDateStr = formatYMD(plan.start_date);
      const endDateStr = formatYMD(plan.end_date);

      // Группировка блюд по датам
      const mealsByDate = {};
      meals.forEach(meal => {
        const dStr = formatYMD(meal.meal_date);
        if (!mealsByDate[dStr]) mealsByDate[dStr] = [];
        mealsByDate[dStr].push(meal);
      });

      // Генерация всех дней плана
      const planDays = [];
      let current = new Date(startDateStr);
      let end = new Date(endDateStr);
      while (current <= end) {
        planDays.push(formatYMD(current));
        current.setDate(current.getDate() + 1);
      }
    %>


    
    <div class="plan-info">
      <p>Период: <strong><%= new Date(startDateStr).toLocaleDateString() %></strong> — <strong><%= new Date(endDateStr).toLocaleDateString() %></strong></p>
    </div>

    <div class="glass-panel add-meal-section">
      <h2 style="font-family: 'Caveat', cursive; font-size: 2.5rem; color: var(--color-text-main); border-left: 5px solid var(--color-accent-primary); padding-left: 15px; margin-bottom: 20px;">Добавить Блюдо</h2>
      <form action="/api/plans/add_meal" method="POST" style="background: transparent; box-shadow: none; border: none; padding: 0; margin: 0;">
        <input type="hidden" name="plan_id" value="<%= plan.plan_id %>" />
        
        <div class="grid-3" style="margin-bottom: 15px;">
          <div>
            <label>Дата:</label>
            <input type="date" name="meal_date" class="form-control" min="<%= startDateStr %>" max="<%= endDateStr %>" required />
          </div>
          <div>
            <label>Прием пищи:</label>
            <select name="meal_type" class="form-control" required>
              <option value="Завтрак">Завтрак</option>
              <option value="Обед">Обед</option>
              <option value="Ужин">Ужин</option>
              <option value="Перекус">Перекус</option>
            </select>
          </div>
          <div>
            <label>Рецепт:</label>
            <select name="recipe_id" class="form-control" required>
              <% allRecipes.forEach(recipe => { %>
                <option value="<%= recipe.recipe_id %>"><%= recipe.title %></option>
              <% }); %>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Добавить в план</button>
      </form>
    </div>

    <div class="calendar-section">
      <% planDays.forEach(day => { %>
        <div class="day-card">
          <div class="day-header">
            <%= new Date(day).toLocaleDateString('ru-RU', { weekday: 'long', day: 'numeric', month: 'long' }) %>
          </div>
          
          <% if (mealsByDate[day] && mealsByDate[day].length > 0) { %>
            <ul class="meal-list">
              <% mealsByDate[day].forEach(meal => { %>
                <li class="meal-item <%= meal.is_cooked ? 'cooked' : '' %>" id="meal-<%= meal.plan_meal_id %>">
                  <span class="meal-type"><%= meal.meal_type %></span>
                  <a href="/api/recipes/view/<%= meal.recipe_id %>" class="meal-title"><%= meal.title %></a>
                  
                  <div class="meal-actions">
                    <% if (!meal.is_cooked) { %>
                      <button class="btn btn-cook" onclick="cookMeal('<%= meal.plan_meal_id %>')">🍳 Приготовить</button>
                    <% } else { %>
                      <span class="status-cooked">✅ Приготовлено</span>
                    <% } %>
                    <button class="btn btn-delete" onclick="removeMeal('<%= meal.plan_meal_id %>')" title="Удалить">🗑️ Удалить</button>
                  </div>
                </li>
              <% }); %>
            </ul>
          <% } else { %>
            <div class="empty-day">На этот день ничего не запланировано.</div>
          <% } %>
        </div>
      <% }); %>
    </div>

    <div class="tools-section">
      <form action="/api/shopping_list/generate" method="POST">
        <input type="hidden" name="plan_id" value="<%= plan.plan_id %>" />
        <button type="submit" class="btn btn-shopping">🛒 Список Покупок</button>
      </form>
      <button class="btn btn-print" onclick="window.print()">🖨️ Распечатать План</button>
    </div>
    </div>

    <script>
      async function removeMeal(planMealId) {
        if (!confirm("Удалить это блюдо из плана?")) return;
        try {
          const response = await fetch(`/api/plans/remove_meal/${planMealId}`, { method: "DELETE" });
          if (response.ok) {
            window.location.reload();
          } else {
            const res = await response.json();
            alert(`Ошибка: ${res.error}`);
          }
        } catch (error) {
          alert("Ошибка сети при удалении.");
        }
      }

      async function cookMeal(planMealId) {
        if (!confirm("Отметить как приготовленное? Ингредиенты будут списаны из вашего инвентаря.")) return;
        try {
          const response = await fetch(`/api/plans/cook_meal`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ plan_meal_id: planMealId })
          });
          if (response.ok) {
            window.location.reload();
          } else {
            const res = await response.json();
            alert(`Ошибка: ${res.error}`);
          }
        } catch (error) {
          alert("Ошибка сети при обновлении статуса.");
        }
      }
    </script>
  </body>
</html>
