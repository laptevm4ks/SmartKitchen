<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Форма Добавления Рецепта</title>
    <link rel="stylesheet" href="/style.css">
    <%- include('_pwa_head') %>
    <style>
      #ingredients-container > div {
        background: var(--color-highlight);
        border: 2px dashed var(--color-bg-accent);
        border-radius: 25px 12px 30px 18px;
        padding: 25px;
        margin: 20px 0;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr auto;
        gap: 15px;
        align-items: end;
      }
      #ingredients-container > div > div {
        display: flex;
        flex-direction: column;
      }
      .remove-ingredient-btn {
        background-color: #ef5350;
        border-color: #c62828;
        box-shadow: 4px 6px 0px #c62828;
        padding: 10px 20px;
        font-size: 0.9rem;
        height: fit-content;
      }
      .remove-ingredient-btn:hover { background-color: #f44336; color: white; }
      @media (max-width: 992px) {
        #ingredients-container > div { grid-template-columns: 1fr; gap: 15px; }
        .remove-ingredient-btn { width: 100%; }
      }
    </style>
  </head>
  <body>
    <%- include('partials/header', { showBackButton: true, extraLinks: [{ href: '/api/recipes', text: 'Рецепты' }] }) %>
    <div class="app-container">
    <div id="message-box" style="display: none"></div>
      <div class="glass-panel">
        <form id="recipeForm" style="display:flex; flex-direction:column; gap:15px; background: transparent; box-shadow: none; border: none; padding: 0;">
          <div>
            <label for="title">Название Рецепта</label>
            <input type="text" id="title" class="form-control" required value="Панкейки на молоке" />
          </div>

          <div class="grid-3">
            <div>
              <label for="servings">Количество порций</label>
              <input type="number" id="servings" class="form-control" value="4" />
            </div>

            <div>
              <label for="prep_time">Время подготовки (мин)</label>
              <input type="number" id="prep_time" class="form-control" value="10" />
            </div>

            <div>
              <label for="cook_time">Время приготовления (мин)</label>
              <input type="number" id="cook_time" class="form-control" value="15" />
            </div>
          </div>

          <div>
            <label for="description">Краткое описание</label>
            <textarea id="description" class="form-control" rows="2">Идеальный рецепт воздушных американских панкейков.</textarea>
          </div>

          <div>
            <label for="instructions">Инструкции по приготовлению</label>
            <textarea id="instructions" class="form-control" rows="5" required>Смешать сухие ингредиенты. Взбить яйца с молоком. Аккуратно соединить обе смеси. Жарить на разогретой сковороде по 2 минуты с каждой стороны.</textarea>
          </div>

          <h2 style="border-left: 5px solid var(--color-accent-primary); padding-left:15px; border-radius: 5px 0 0 5px; font-family: 'Caveat', cursive; font-size:2.5rem; color:var(--color-text-main);">Ингредиенты</h2>
          <div id="ingredients-container"></div>

          <button type="button" id="add-ingredient-btn" class="btn btn-secondary" style="width: fit-content; background-color: #4caf50; border-color: #2e7d32; box-shadow: 4px 6px 0px #2e7d32;">
            + Добавить Ингредиент
          </button>

          <div style="display: flex; justify-content: center; margin-top: 20px;">
            <button type="submit" id="submit-btn" class="btn btn-primary" style="padding: 15px 40px; font-size: 1.2rem;">💾 Сохранить Рецепт</button>
          </div>
        </form>
      </div>
    </div>

    <template id="ingredient-template">
      <div>
        <div>
          <label>Ингредиент</label>
          <select name="ingredient_id" class="ingredient-select form-control" required></select>
        </div>
        <div>
          <label>Кол-во:</label>
          <input type="number" step="0.01" name="quantity" class="form-control" required placeholder="0.00" />
        </div>
        <div>
          <label>Ед. изм.:</label>
          <input type="text" name="unit" class="form-control" required placeholder="гр" />
        </div>
        <div>
          <label>Примечания:</label>
          <input type="text" name="notes" class="form-control" placeholder="опц." />
        </div>
        <button type="button" class="btn btn-danger remove-ingredient-btn">Удалить</button>
      </div>
    </template>

    <script>
      const currentUserId = parseInt("<%= userId %>", 10) || null;
      let availableIngredients = [];
      const messageBox = document.getElementById("message-box");
      const submitBtn = document.getElementById("submit-btn");
      const container = document.getElementById("ingredients-container");
      const addButton = document.getElementById("add-ingredient-btn");
      const form = document.getElementById("recipeForm");
      const template = document.getElementById("ingredient-template");

      if (!currentUserId) {
        showMessage("Ошибка: Пользователь не авторизован.", "error");
        submitBtn.disabled = true;
        addButton.disabled = true;
        throw new Error("User ID is missing.");
      }

      async function fetchIngredients() {
        try {
          const response = await fetch("/api/ingredients");
          if (!response.ok) throw new Error(`Ошибка ${response.status}`);
          availableIngredients = await response.json();
          return true;
        } catch (error) {
          console.error("Ошибка загрузки справочника ингредиентов:", error);
          showMessage(`Ошибка: ${error.message}`, "error");
          return false;
        }
      }

      function showMessage(message, type) {
        messageBox.textContent = message;
        messageBox.className = type;
        messageBox.style.display = "block";
        setTimeout(() => { messageBox.style.display = "none"; }, 4000);
      }

      function populateSelect(selectElement) {
        selectElement.innerHTML = '<option value="" disabled selected>-- Выберите ингредиент --</option>';
        availableIngredients.forEach((ing) => {
          const option = document.createElement("option");
          option.value = ing.ingredient_id || ing.id;
          option.textContent = ing.name;
          option.setAttribute("data-unit", ing.unit_of_measure);
          selectElement.appendChild(option);
        });
      }

      function addIngredientField() {
        if (availableIngredients.length === 0) {
          showMessage("Справочник ингредиентов не загружен или пуст.", "error");
          return;
        }
        const clone = template.content.cloneNode(true);
        const select = clone.querySelector('select[name="ingredient_id"]');
        const unitInput = clone.querySelector('input[name="unit"]');
        populateSelect(select);
        if (select.options.length > 1) {
          select.selectedIndex = 1;
          const defaultUnit = select.options[select.selectedIndex].getAttribute("data-unit");
          unitInput.value = defaultUnit || "";
        }
        container.appendChild(clone);
      }

      document.addEventListener("DOMContentLoaded", async () => {
        const loadedSuccessfully = await fetchIngredients();
        if (loadedSuccessfully) {
          addButton.addEventListener("click", addIngredientField);
          addIngredientField();
        } else {
          addButton.disabled = true;
        }
        container.addEventListener("click", (e) => {
          if (e.target.matches(".remove-ingredient-btn")) { e.target.closest("div").remove(); }
        });
        container.addEventListener("change", (e) => {
          if (e.target.matches(".ingredient-select")) {
            const group = e.target.closest("div");
            const unitInput = group.querySelector('input[name="unit"]');
            const defaultUnit = e.target.options[e.target.selectedIndex].getAttribute("data-unit");
            unitInput.value = defaultUnit || "";
          }
        });
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        const userIdToUse = currentUserId;
        const ingredientGroups = container.querySelectorAll("#ingredients-container > div");
        const ingredientsData = [];
        let isValid = true;
        ingredientGroups.forEach((group) => {
          const ingredient_id_str = group.querySelector('select[name="ingredient_id"]').value;
          const quantity_str = group.querySelector('input[name="quantity"]').value;
          const unit = group.querySelector('input[name="unit"]').value;
          const notes = group.querySelector('input[name="notes"]').value;
          const quantity = parseFloat(quantity_str);
          const ingredient_id = parseInt(ingredient_id_str, 10);
          if (ingredient_id > 0 && !isNaN(quantity) && quantity > 0 && unit) {
            ingredientsData.push({ ingredient_id: ingredient_id, quantity: quantity, unit: unit.trim(), notes: notes.trim() });
          } else { isValid = false; }
        });
        if (!isValid) {
          showMessage("Заполните все обязательные поля для каждого ингредиента.", "error");
          submitBtn.disabled = false;
          return;
        }
        if (ingredientsData.length === 0) {
          showMessage("Добавьте хотя бы один ингредиент.", "error");
          submitBtn.disabled = false;
          return;
        }
        const formData = {
          user_id: userIdToUse,
          title: document.getElementById("title").value.trim(),
          description: document.getElementById("description").value.trim(),
          instructions: document.getElementById("instructions").value.trim(),
          prep_time: parseInt(document.getElementById("prep_time").value) || 0,
          cook_time: parseInt(document.getElementById("cook_time").value) || 0,
          servings: parseInt(document.getElementById("servings").value) || 1,
          ingredients: ingredientsData,
        };
        try {
          const response = await fetch("/api/recipes", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(formData),
          });
          if (response.ok) {
            const result = await response.json();
            showMessage(`Рецепт "${formData.title}" успешно отправлен! (ID: ${result.recipe_id || "N/A"})`, "success");
            form.reset();
            container.innerHTML = "";
            addIngredientField();
          } else {
            const errorText = await response.text();
            showMessage(`Ошибка ${response.status}: ${errorText.substring(0, 70)}...`, "error");
          }
        } catch (error) {
          console.error("Ошибка сети:", error);
          showMessage(`Ошибка сети: ${error.message}`, "error");
        } finally { submitBtn.disabled = false; }
      });
    </script>
  </body>
</html>
