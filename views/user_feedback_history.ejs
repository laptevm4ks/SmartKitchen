<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Мои Отчеты Обратной Связи</title>
    <link rel="stylesheet" href="/style.css">
    <%- include('_pwa_head') %>
    <style>
      .report-list { display: flex; flex-direction: column; gap: 20px; margin-top: 30px; }
      .status-badge { display: inline-block; padding: 5px 15px; border-radius: 15px; font-weight: 700; font-size: 0.9rem; margin-bottom: 15px; color: white; }
      .status-Новый { background-color: #fbc02d; }
      .status-В_работе { background-color: #1e88e5; }
      .status-Решено { background-color: #43a047; }
      .status-Отклонен { background-color: #e53935; }
      .report-header h2 { font-size: 1.5rem; margin-top: 0; margin-bottom: 10px; color: var(--color-accent-primary); }
      .report-date { font-size: 0.9rem; color: #8d6e63; margin-bottom: 15px; padding-bottom: 10px; border-bottom: 1px dashed var(--color-bg-accent); }
      .report-message { border-left: 3px solid var(--color-bg-accent); padding-left: 15px; margin: 15px 0; line-height: 1.6; }
      .report-message strong { color: var(--color-accent-primary); }
      .admin-response-block { margin-top: 20px; padding: 20px; border-radius: 10px; background-color: #f5f5f5; border: 1px dashed var(--color-accent-primary); }
      .admin-response-block h4 { margin-top: 0; margin-bottom: 10px; color: var(--color-text-main); font-weight: 700; }
      .no-reports { text-align: center; padding: 50px; font-size: 1.2rem; color: #8d6e63; font-style: italic; }
      .message-preview { font-style: italic; color: #666; }
      .message-full { margin-top: 10px; padding: 10px; background: rgba(255, 255, 255, 0.7); border-radius: 5px; display: none; }
      .show-more { color: var(--color-accent-primary); cursor: pointer; font-weight: 600; margin-left: 5px; }
      .show-more:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <%- include('partials/header', { showBackButton: true, title: 'История отчетов' }) %>
    <div class="app-container">
    <div class="glass-panel" style="max-width: 1000px; margin: 40px auto;">
      <div style="display: flex; gap: 15px; justify-content: center;">
        <a href="/api/create_feedback" class="btn btn-primary" style="margin: 0;">Отправить новый отчет</a>
      </div>

      <hr style="margin: 25px 0; border: none; border-bottom: 2px dashed var(--color-bg-accent);" />

      <% if (reports.length === 0) { %>
      <div class="no-reports">Вы еще не отправляли отчеты обратной связи.</div>
      <% } else { %>
      <div class="report-list">
        <% for (var i = 0; i < reports.length; i++) { var report = reports[i]; %>
        <div class="glass-panel" style="background-color: var(--color-highlight);">
          <span class="status-badge status-<%= report.status.replace(/\s/g, '_') %>">
            <%= report.status %>
          </span>

          <div class="report-header">
            <h2><%= report.subject %></h2>
            <p class="report-date">
              <strong>Создан:</strong> <%= new Date(report.created_at).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
              <% if (new Date(report.created_at).getTime() !== new Date(report.updated_at).getTime()) { %>
              <br /><strong>Обновлен:</strong> <%= new Date(report.updated_at).toLocaleDateString('ru-RU', { hour: '2-digit', minute: '2-digit' }) %>
              <% } %>
            </p>
          </div>

          <div class="report-message">
            <strong>Ваше сообщение:</strong><br />
            <% if (report.message.length > 200) { %>
            <div class="message-preview" id="preview-<%= i %>">
              <%= report.message.substring(0, 200) %>...
              <span class="show-more" onclick="toggleMessage('<%= i %>')">Показать полностью</span>
            </div>
            <div class="message-full" id="full-<%= i %>">
              <%= report.message.replace(/\n/g, '<br />') %>
              <div style="margin-top: 10px"><span class="show-more" onclick="toggleMessage('<%= i %>')">Скрыть</span></div>
            </div>
            <% } else { %> <%= report.message.replace(/\n/g, '<br />') %> <% } %>
          </div>

          <% if (report.admin_response && report.admin_response.trim() !== '') { %>
          <div class="admin-response-block">
            <h4>Ответ администратора:</h4>
            <p><%= report.admin_response.replace(/\n/g, '<br />') %></p>
          </div>
          <% } else if (report.status === 'Решено' || report.status === 'Отклонен') { %>
          <div class="admin-response-block">
            <h4>ℹ️ Статус изменен:</h4>
            <p>Администратор обработал ваш запрос. Статус: <strong><%= report.status %></strong></p>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>

    <script>
      function toggleMessage(index) {
        var preview = document.getElementById("preview-" + index);
        var full = document.getElementById("full-" + index);
        if (preview.style.display === "none" || !preview.style.display) {
          preview.style.display = "none";
          full.style.display = "block";
        } else {
          full.style.display = "none";
          preview.style.display = "block";
        }
      }
    </script>
  </body>
</html>
